<?xml version="1.0"?>
<robot name="spot_micro_leg_test_stand">

  <!--
    SpotMicro-inspired single leg on a fixed test stand.
    Four-bar parallel linkage knee drive (MG996R-style).

    Dimensions (from V1 Fusion CAD export):
      L1 (shoulder offset)   = 0.055 m
      L2 (femur)             = 0.060 m
      L3 (tibia)             = 0.060 m
      Ground link            = 0.033 m  (between hip and knee-drive pivots)
      Crank (servo arm)      = 0.029 m
      Coupler (push-rod)     = 0.060 m

    Tree structure (PyBullet needs open chain; loop closed by constraint):
      base_link
        └─ hip_abduction → shoulder_link
             ├─ hip_flexion → femur_link
             │     └─ knee_passive → tibia_link
             │           └─ foot_fixed → foot_link
             └─ knee_drive → crank_link
                   └─ coupler_passive → coupler_link
                         [constraint closes loop to knee pivot]
  -->

  <!-- ============ TEST STAND PLATFORM (fixed to world) ============ -->
  <link name="base_link">
    <visual>
      <geometry><box size="0.12 0.12 0.01"/></geometry>
      <material name="aluminum"><color rgba="0.7 0.7 0.7 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.12 0.12 0.01"/></geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <!-- ============ HIP ABDUCTION (q1, around X) ============ -->
  <joint name="hip_abduction" type="revolute">
    <parent link="base_link"/>
    <child  link="shoulder_link"/>
    <origin xyz="0 0 -0.005" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.548" upper="0.548" effort="12" velocity="6.28"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <link name="shoulder_link">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry><sphere radius="0.014"/></geometry>
      <material name="joint_gray"><color rgba="0.45 0.45 0.45 1.0"/></material>
    </visual>
    <!-- lateral offset cylinder (along -Y for right leg) -->
    <visual>
      <origin xyz="0 -0.0275 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.012" length="0.055"/></geometry>
      <material name="blue"><color rgba="0.20 0.45 0.85 1.0"/></material>
    </visual>
    <!-- ground link bar connecting hip pivot to knee-drive pivot -->
    <visual>
      <origin xyz="-0.0165 -0.055 0" rpy="0 0 0"/>
      <geometry><box size="0.033 0.008 0.008"/></geometry>
      <material name="bracket"><color rgba="0.55 0.55 0.55 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 -0.0275 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.012" length="0.055"/></geometry>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <origin xyz="0 -0.0275 0"/>
      <inertia ixx="0.00008" ixy="0" ixz="0" iyy="0.00008" iyz="0" izz="0.00002"/>
    </inertial>
  </link>

  <!-- ============ HIP FLEXION (q2, around Y) — drives femur ============ -->
  <joint name="hip_flexion" type="revolute">
    <parent link="shoulder_link"/>
    <child  link="femur_link"/>
    <origin xyz="0 -0.055 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.618" upper="2.618" effort="12" velocity="6.28"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <link name="femur_link">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry><sphere radius="0.013"/></geometry>
      <material name="joint_gray"/>
    </visual>
    <visual>
      <origin xyz="0 0 -0.030"/>
      <geometry><cylinder radius="0.010" length="0.060"/></geometry>
      <material name="red"><color rgba="0.85 0.25 0.20 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.030"/>
      <geometry><cylinder radius="0.010" length="0.060"/></geometry>
    </collision>
    <inertial>
      <mass value="0.12"/>
      <origin xyz="0 0 -0.030"/>
      <inertia ixx="0.00008" ixy="0" ixz="0" iyy="0.00008" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <!-- ============ KNEE (passive revolute, driven by four-bar constraint) ============ -->
  <joint name="knee_passive" type="revolute">
    <parent link="femur_link"/>
    <child  link="tibia_link"/>
    <origin xyz="0 0 -0.060" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.618" upper="2.618" effort="0" velocity="10.0"/>
    <dynamics damping="0.01" friction="0.01"/>
  </joint>

  <link name="tibia_link">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry><sphere radius="0.012"/></geometry>
      <material name="joint_gray"/>
    </visual>
    <visual>
      <origin xyz="0 0 -0.030"/>
      <geometry><cylinder radius="0.008" length="0.060"/></geometry>
      <material name="dark_blue"><color rgba="0.12 0.22 0.60 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.030"/>
      <geometry><cylinder radius="0.008" length="0.060"/></geometry>
    </collision>
    <inertial>
      <mass value="0.08"/>
      <origin xyz="0 0 -0.030"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.000005"/>
    </inertial>
  </link>

  <!-- ============ FOOT (fixed to tibia tip) ============ -->
  <joint name="foot_fixed" type="fixed">
    <parent link="tibia_link"/>
    <child  link="foot_link"/>
    <origin xyz="0 0 -0.060"/>
  </joint>

  <link name="foot_link">
    <visual>
      <geometry><sphere radius="0.012"/></geometry>
      <material name="green"><color rgba="0.20 0.80 0.25 1.0"/></material>
    </visual>
    <collision>
      <geometry><sphere radius="0.012"/></geometry>
    </collision>
    <inertial>
      <mass value="0.02"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>

  <!-- ============ KNEE DRIVE (four-bar crank, on shoulder) ============ -->
  <!--
    The knee-drive servo pivot is 33mm behind (-X) the hip flexion pivot,
    at the same lateral offset. Its crank arm (29mm) drives the four-bar.
  -->
  <joint name="knee_drive" type="revolute">
    <parent link="shoulder_link"/>
    <child  link="crank_link"/>
    <origin xyz="-0.033 -0.055 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.618" upper="2.618" effort="12" velocity="6.28"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <link name="crank_link">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry><sphere radius="0.010"/></geometry>
      <material name="crank_pivot"><color rgba="0.6 0.4 0.1 1.0"/></material>
    </visual>
    <visual>
      <origin xyz="0 0 -0.0145"/>
      <geometry><cylinder radius="0.007" length="0.029"/></geometry>
      <material name="orange"><color rgba="0.95 0.55 0.10 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.0145"/>
      <geometry><cylinder radius="0.007" length="0.029"/></geometry>
    </collision>
    <inertial>
      <mass value="0.04"/>
      <origin xyz="0 0 -0.0145"/>
      <inertia ixx="0.000005" ixy="0" ixz="0" iyy="0.000005" iyz="0" izz="0.000002"/>
    </inertial>
  </link>

  <!-- ============ COUPLER (push-rod connecting crank to knee) ============ -->
  <joint name="coupler_passive" type="revolute">
    <parent link="crank_link"/>
    <child  link="coupler_link"/>
    <origin xyz="0 0 -0.029" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="0" velocity="10.0"/>
    <dynamics damping="0.01" friction="0.01"/>
  </joint>

  <link name="coupler_link">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
      <material name="joint_gray"/>
    </visual>
    <visual>
      <origin xyz="0 0 -0.030"/>
      <geometry><cylinder radius="0.006" length="0.060"/></geometry>
      <material name="coupler_green"><color rgba="0.25 0.65 0.35 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.030"/>
      <geometry><cylinder radius="0.006" length="0.060"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 -0.030"/>
      <inertia ixx="0.00003" ixy="0" ixz="0" iyy="0.00003" iyz="0" izz="0.000003"/>
    </inertial>
  </link>

</robot>

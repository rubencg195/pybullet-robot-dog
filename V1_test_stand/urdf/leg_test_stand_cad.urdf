<?xml version="1.0"?>
<!--
  V1 — same kinematic chain as V0 (SpotMicro-style test stand), visuals/collisions
  from mesh files. Export one STL (or OBJ) per link into ../meshes/:

    base_plate.stl   shoulder_link.stl   upper_leg.stl   lower_leg.stl   foot.stl

  Place meshes so that, at zero pose, they line up with V0 cylinder geometry;
  joint axes and origins match V0 exactly until you intentionally retune.
-->
<robot name="spot_micro_leg_test_stand_cad">

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/base_plate.stl" scale="1 1 1"/>
      </geometry>
      <material name="aluminum"><color rgba="0.7 0.7 0.7 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/base_plate.stl" scale="1 1 1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="hip_abduction" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 -0.005" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.548" upper="0.548" effort="12" velocity="6.28"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <link name="shoulder_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/shoulder_link.stl" scale="1 1 1"/>
      </geometry>
      <material name="blue"><color rgba="0.2 0.45 0.85 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/shoulder_link.stl" scale="1 1 1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.10"/>
      <origin xyz="0 -0.0275 0"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="hip_flexion" type="revolute">
    <parent link="shoulder_link"/>
    <child link="upper_leg_link"/>
    <origin xyz="0 -0.055 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.618" upper="2.618" effort="12" velocity="6.28"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <link name="upper_leg_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/upper_leg.stl" scale="1 1 1"/>
      </geometry>
      <material name="red"><color rgba="0.85 0.25 0.2 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/upper_leg.stl" scale="1 1 1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <origin xyz="0 0 -0.0535"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.00002"/>
    </inertial>
  </link>

  <joint name="knee_flexion" type="revolute">
    <parent link="upper_leg_link"/>
    <child link="lower_leg_link"/>
    <origin xyz="0 0 -0.107" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.618" upper="2.618" effort="12" velocity="6.28"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <link name="lower_leg_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/lower_leg.stl" scale="1 1 1"/>
      </geometry>
      <material name="dark_blue"><color rgba="0.12 0.22 0.6 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/lower_leg.stl" scale="1 1 1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.10"/>
      <origin xyz="0 0 -0.065"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="foot_fixed" type="fixed">
    <parent link="lower_leg_link"/>
    <child link="foot_link"/>
    <origin xyz="0 0 -0.130" rpy="0 0 0"/>
  </joint>

  <link name="foot_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/foot.stl" scale="1 1 1"/>
      </geometry>
      <material name="green"><color rgba="0.2 0.8 0.25 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/foot.stl" scale="1 1 1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.02"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>

</robot>
